# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Shopify Admin (required)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Optional market pricing (ISO-2)
SHOPIFY_MARKET_COUNTRY=
# Public storefront origin for product links
SHOPIFY_STOREFRONT_URL=https://www.example.com

# Optional multi-region stores
# SHOPIFY_FR_STORE_DOMAIN=
# SHOPIFY_FR_ADMIN_ACCESS_TOKEN=
# SHOPIFY_DE_STORE_DOMAIN=
# SHOPIFY_DE_ADMIN_ACCESS_TOKEN=
# SHOPIFY_ES_STORE_DOMAIN=
# SHOPIFY_ES_ADMIN_ACCESS_TOKEN=
# SHOPIFY_UK_STORE_DOMAIN=
# SHOPIFY_UK_ADMIN_ACCESS_TOKEN=

# Redis (required for multi-instance production)
REDIS_URL=
REDIS_KEY_PREFIX=n8napp
PRODUCT_CACHE_TTL_SECONDS=1800
PRODUCT_CACHE_EMPTY_TTL_SECONDS=20

# Public widget
NEXT_PUBLIC_STORE_NAME=Our Store
# Hostname only (no protocol) — used to allowlist product links in chat
NEXT_PUBLIC_STOREFRONT_HOST=www.example.com

# Future n8n automations
# N8N_WEBHOOK_URL=
